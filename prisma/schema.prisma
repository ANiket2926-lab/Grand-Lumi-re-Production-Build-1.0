generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      Role      @default(USER)
  bookings  Booking[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Hall {
  id           String    @id @default(cuid())
  name         String
  description  String
  capacity     Int
  priceWeekday Float
  priceWeekend Float
  images       String[]
  bookings     Booking[]
  createdAt    DateTime  @default(now())
}

model Booking {
  id         String        @id @default(cuid())
  userId     String
  hallId     String
  startDate  DateTime
  endDate    DateTime
  guests     Int
  eventType  String
  status     BookingStatus @default(PENDING)
  totalPrice Float
  user       User          @relation(fields: [userId], references: [id])
  hall       Hall          @relation(fields: [hallId], references: [id])
  payment    Payment?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Payment {
  id         String   @id @default(cuid())
  bookingId  String   @unique
  razorpayId String?
  amount     Float
  status     String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  createdAt  DateTime @default(now())
}

model BlockedDate {
  id     String   @id @default(cuid())
  hallId String
  date   DateTime
  reason String?
}

enum Role {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
}
